    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment Session (Stripe)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data) {",
                  "  if (json.data.payment && json.data.payment.id) pm.collectionVariables.set('paymentId', json.data.payment.id);",
                  "  if (json.data.payment && json.data.payment.transactionId) pm.collectionVariables.set('stripeSessionId', json.data.payment.transactionId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{customerAccessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rentalOrderId\": \"{{rentalOrderId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/payments/create",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments",
                "create"
              ]
            },
            "description": "Rental order must be in CONFIRMED status. Returns a Stripe `checkoutUrl` to complete payment in a browser."
          },
          "response": []
        },
